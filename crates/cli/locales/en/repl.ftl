repl-goodbye = Goodbye.
repl-agent-switched = Switched Agent → {$id}
repl-help-equiv = Each line continues this line-REPL session (multi-turn, same engine as TUI). One-shot equivalent:\n  anycode run -C {$cwd} --agent {$agent} "…"
