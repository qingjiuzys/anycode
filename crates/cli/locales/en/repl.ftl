repl-tty-title = anyCode REPL · v{$version}
repl-tty-sub = {$cwd} · Agent {$agent}
repl-title-embedded =  anyCode · v{$version} 
repl-row-approval = Approvals: skipped for this process (-I etc.; config unchanged)
repl-dock-approval-on = approvals on
repl-dock-approval-off = approvals off
repl-dock-approval-skipped = approvals skipped (-I)
repl-session-cleared = Session cleared — fresh context for this agent (scrollback above is unchanged).
repl-hint-debug = Verbose logs: `anycode --debug repl` or `RUST_LOG=info`
repl-hint-completion = `/` · ↑↓ · Tab · Enter · Ctrl+U clear line (Esc does not — IME-friendly)
repl-hint-ime = If normal paste fails, try Ctrl+Shift+V (reads the system clipboard directly). Or use WezTerm / iTerm2.
repl-hint-repl-layout = Default Inline viewport (transcript + dock). Page during the session; full transcript is kept in terminal scrollback on exit.
repl-hud-turn-summary-in = chunked {$s}s · ctx {$in_k}k in
repl-hud-turn-summary-io = chunked {$s}s · in {$in_k}k · out {$out_k}k
# Line / stream REPL dock slash menu (not fullscreen TUI); may mirror tui-slash-*
repl-slash-nav = ↑↓ · Enter submit · Tab pick · Shift+Tab prev
repl-slash-range = {$s}–{$e} / {$n}
repl-busy-natural = A reply is still generating; wait to send a new message, or use slash commands like /help or /clear.
repl-stream-error-google-geo = Google Generative Language API rejected the request: your region is not supported for this API (User location is not supported). Try another provider or model in config, or check Google’s regional availability.
repl-stream-error-stderr-hint = Full error was printed to stderr.
