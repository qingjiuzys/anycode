cli-short = anyCode - terminal AI agent for developers (Rust)
cli-long = anyCode is a Rust CLI for local tool-using agents. Default (`anycode` with no subcommand): stream terminal UI on an interactive TTY; non-TTY uses line-at-a-time stdio. Tune with global --agent, -C/--directory, --model, --resume. Alternate screen: config terminal.alternateScreen or ANYCODE_TERM_REPL_*, ANYCODE_TERM_ALT_SCREEN (see docs).
flag-debug = Enable debug logging
flag-config = Path to config JSON
flag-ignore-approval = Skip tool y/n approval for this process (temporary; deny rules still apply). Env ANYCODE_IGNORE_APPROVAL=1 is equivalent.
flag-agent = Agent id (default: from config runtime mode)
flag-directory = Working directory for the default interactive session
flag-model = Override default model for this process (long option --model only)
flag-resume = Resume saved session UUID (~/.anycode/sessions/)
flag-repl-debug-events = Log crossterm keyboard/paste events to stderr (redacted)
cmd-scheduler-about = Built-in scheduler: run CronCreate jobs from ~/.anycode/tasks/orchestration.json
cmd-scheduler-directory = Working directory for each triggered agent task
cmd-scheduler-reload-secs = Re-read orchestration.json and cap sleep between ticks (seconds)
cmd-run-about = Run a single task
cmd-run-agent = Agent type
cmd-run-prompt = Task description
cmd-run-directory = Working directory
cmd-list-agents-about = List available agents
cmd-list-tools-about = List available tools
cmd-daemon-about = HTTP daemon (long-running)
cmd-daemon-bind = Bind address
cmd-config-about = Interactive configuration wizard
cmd-setup-about = First-time setup: workspace → model/API wizard → memory / embeddings (interactive TTY) → optional channels (WeChat, etc.)
cmd-setup-channel = Channel for setup: wechat, telegram, discord, or skip/none to skip
setup-channel-prompt = Choose a channel to connect
setup-channel-opt-skip = Skip (configure later with anycode channel …)
setup-channel-skipped-hint = Skipped channel setup. Later: anycode channel wechat / telegram / discord
setup-non-tty-skip-hint = Non-interactive, no --channel: skipping channel setup. Use: anycode setup --channel wechat|telegram|discord|skip
cmd-setup-data-dir = WeChat data directory (default ~/.anycode/wechat)

setup-memory-non-tty-hint = Non-interactive terminal: skipping the memory wizard. Use `anycode config` on a TTY or edit JSON `memory` later.
setup-memory-prompt = Memory & vectors (noop disables persistence; Markdown = hybrid; vectors = pipeline + embeddings; HTTP embeddings reuse chat `api_key`)
setup-memory-opt-skip = Skip (keep current memory settings)
setup-memory-opt-noop = Disable memory (`memory.backend=noop`)
setup-memory-opt-markdown = Markdown memories + keyword index (`memory.backend=hybrid`)
setup-memory-opt-remote-vector = Pipeline + remote embeddings (OpenAI-compatible `embedding_base_url` + `embedding_model`)
setup-memory-opt-local-vector = Pipeline + local ONNX (requires embedding-local build)
setup-memory-http-apikey-hint = Embedding HTTP calls reuse the configured `api_key` (same as chat). Override later in JSON if needed.
setup-memory-http-prompt-base-url = Embedding base URL (OpenAI-compatible API root incl. /v1, e.g. https://api.openai.com/v1)
setup-memory-http-prompt-model = Embedding model id (e.g. text-embedding-3-small)
setup-memory-http-empty-url = Embedding base URL must not be empty
setup-memory-http-empty-model = Embedding model id must not be empty
setup-memory-http-probe-warn = Quick connectivity check failed ({ $reason }). You can skip this on offline installs.
setup-memory-http-probe-continue = Save this embedding base URL anyway?
setup-memory-http-probe-aborted = HTTP embedding setup cancelled; nothing saved.
setup-memory-local-prompt-ep = Model download endpoint (mirror if huggingface.co is slow from your region)
setup-memory-ep-official = Hugging Face official (huggingface.co)
setup-memory-ep-mirror = China mirror (hf-mirror.com)
setup-memory-ep-env = Do not write endpoint (respect existing HF_ENDPOINT if set)
setup-memory-local-prompt-model = Local embedding model (fastembed built-in enums)
setup-memory-local-model-allmini = AllMiniLML6-v2 (small English, common default)
setup-memory-local-model-bge-zh = bge-small-zh (Chinese)
setup-memory-local-model-e5-base = multilingual-e5-base (multilingual)
setup-memory-local-model-bge-en = bge-small-en-v1.5 (English)
setup-memory-local-done-print = Saved local embeddings (memory.backend=pipeline, embedding_provider=local). Build with `cargo build -p anycode --features embedding-local` if embeddings are unsupported in this binary.

cmd-channel-about = Channel commands (wechat / telegram / discord)
cmd-telegram-about = Telegram bridge (Bot Token + polling)
cmd-telegram-bot-token = Telegram bot token (fallback: TELEGRAM_BOT_TOKEN)
cmd-telegram-chat-id = Optional chat id allowlist
cmd-telegram-agent = Agent id used for incoming Telegram messages
cmd-telegram-directory = Working directory used when running tasks
cmd-discord-about = Discord bridge (Bot Token + channel polling)
cmd-discord-bot-token = Discord bot token (fallback: DISCORD_BOT_TOKEN)
cmd-discord-channel-id = Discord channel id (fallback: DISCORD_CHANNEL_ID)
cmd-discord-agent = Agent id used for incoming Discord messages
cmd-discord-directory = Working directory used when running tasks
cmd-model-about = Model and credentials (interactive when no subcommand)
cmd-test-security-about = Exercise security / approvals
cmd-test-security-tool = Tool name
cmd-test-security-input = Tool input (JSON)
cmd-wechat-about = WeChat: scan to bind; installs login autostart bridge when successful
cmd-wechat-data-dir = Data directory (default ~/.anycode/wechat; WCC_DATA_DIR for legacy paths)
cmd-wechat-bridge-hint = Invoked by LaunchAgent/systemd to run the message bridge (do not use manually)
cmd-wechat-agent = Same as anycode run --agent (only with --run-as-bridge)
mcp-oauth-about = Browser OAuth for remote MCP; prints access token (requires --features mcp-oauth)
mcp-oauth-url = MCP endpoint URL, e.g. https://example.com/mcp
mcp-oauth-host = Local callback bind address (127.0.0.1 recommended)
mcp-oauth-port = Local callback port
mcp-oauth-callback = Callback path (must match redirect_uri, default /callback)
mcp-oauth-client-metadata = OAuth client metadata URL (SEP-991; optional)
mcp-oauth-scope = Requested scope (repeatable)
mcp-oauth-no-browser = Do not open browser; only print authorization URL
mcp-oauth-write-token = Write access_token as one line to this file (mind permissions)
mcp-oauth-credentials-store = Write full OAuth JSON (refresh_token) for ANYCODE_MCP_SERVERS oauth_credentials_path
model-list-about = List models (z.ai static catalog)
model-list-json = JSON output
model-list-plain = Plain output (one model id per line)
model-status-about = Show configured model status
model-status-json = JSON output
model-set-about = Set default model
model-set-model = Model id (e.g. glm-5)
cmd-mcp-about = MCP helper commands (e.g. OAuth login; requires --features mcp-oauth)
oauth-access-token-label = access_token:
oauth-creds-saved = OAuth credentials (refresh token included when issued) saved to {$path}
oauth-write-token-err = write {$path}: {$err}
oauth-wrote-token = Wrote access_token only to {$path}
