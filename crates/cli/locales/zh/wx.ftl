wx-help = 可用命令：\n\n会话：/help /clear /reset /status /history [n] /undo [n] /compact\n配置：/cwd [路径] /model <名> /permission [模式] /prompt [内容|clear]\n其他：/version\n直接发文字则交给 anycode Agent。\n\n注：/skills 与 /<skill> 在 Rust 桥未实现；可用自然语言描述需求。
wx-version = anycode wx 桥 (Rust) + anycode {$version}
wx-cmd-clear-ok = ✅ 会话已清除。
wx-cmd-reset-ok = ✅ 已完全重置会话。
wx-cmd-status = 📊 工作目录: {$cwd}\n模型(会话): {$model}\n权限模式: {$mode}\n状态: {$st}\n会话ID: {$sid}
