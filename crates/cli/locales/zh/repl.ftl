repl-tty-title = anyCode REPL · v{$version}
repl-tty-sub = {$cwd} · Agent {$agent}
repl-title-embedded =  anyCode · v{$version} 
repl-row-approval = 审批 本进程已跳过工具 y/n（-I 等；配置未改写）
repl-dock-approval-on = 审批 开
repl-dock-approval-off = 审批 关
repl-dock-approval-skipped = 审批 已跳过（-I）
repl-session-cleared = 已清空本会话消息并重建上下文（上方终端滚动历史仍在）。
repl-hint-debug = 详细日志：`anycode --debug repl` 或 `RUST_LOG=info`
repl-hint-completion = `/` · ↑↓ · Tab · Enter · Ctrl+U 清空行（Esc 不清空，避免与输入法冲突）
repl-hint-ime = 若 Cmd+V 无效：请试 Ctrl+Shift+V（直连系统剪贴板，不依赖终端粘贴协议）。仍失败可换 WezTerm / iTerm2。
repl-hint-repl-layout = 默认 Inline 视口（正文 + 底栏）。支持会话内翻页；退出后完整内容保留在终端滚动历史。
repl-hud-turn-summary-in = 本轮 {$s}s · 约 {$in_k}k tokens（输入）
repl-hud-turn-summary-io = 本轮 {$s}s · 入 {$in_k}k · 出 {$out_k}k tokens
# 行式 / 流式 REPL 底栏斜杠补全（非全屏 TUI；与 tui-slash-* 文案可保持一致）
repl-slash-nav = ↑↓ Enter 发送 · Tab 选用 · Shift+Tab 上一条
repl-slash-range = {$s}–{$e} / 共 {$n} 条
repl-busy-natural = 当前仍有一轮回复在生成；请稍候再发送新消息，或使用 /help、/clear 等斜杠命令。
repl-goodbye = 再见。
repl-agent-switched = 已切换 Agent → {$id}
repl-help-equiv = 每行会在当前行式会话中追加一轮（多轮，与 TUI 同一套消息引擎）。单次任务等价:\n  anycode run -C {$cwd} --agent {$agent} "…"
repl-help-cmds = 命令：/help · /clear · /compact · /session · /context · /cost · /export · /paste · /agents · /tools · /exit · /general-purpose · /explore · /plan
repl-cost-disclaimer = 不提供美元/人民币等货币估算；计费以各提供商账单为准。以下为本地 token 快照（与 /context 同源）。
repl-export-done = 已导出会话到 {$path}
repl-export-failed = 导出失败
repl-export-failed-detail = 导出失败：{$err}
repl-list-agents-title = 🤖 可用 Agents：
repl-agent-desc-gp =     通用复杂任务
repl-agent-desc-explore =     快速浏览代码库
repl-agent-desc-plan =     架构与方案规划
repl-list-switch = 会话切换（REPL / TUI）：/general-purpose  ·  /explore  ·  /plan
repl-list-usage = 用法：
repl-list-usage-line =   anycode run --agent general-purpose "你的任务"
repl-list-tools-title = 🔧 可用工具：
repl-security-title = 安全：
repl-security-read =   • FileRead、Glob、Grep：只读，自动通过
repl-security-approval =   • FileWrite、Bash：需审批
repl-security-sandbox =   • security.sandbox_mode=true：读写/Glob/Grep 路径限制在任务 cwd；Bash 亦使用该 cwd
repl-task-out = 📝 任务日志：{$path}
repl-task-run = ⏳ 执行任务中…
repl-task-ok = ✅ 任务完成
repl-output-header = 输出：
repl-written-header = 已写入：
repl-written-line =   • {$line}
repl-task-fail = ❌ 任务失败：{$err}
repl-task-details = 详情：{$details}
repl-task-partial = ⚠️  部分成功：
repl-task-partial-done =   已完成：{$done}
repl-task-partial-rem =   未完成：{$rem}
repl-daemon-http = 🌐 Daemon HTTP http://{$addr}
repl-daemon-get =   GET  /health
repl-daemon-post =   POST /v1/tasks  Content-Type: application/json
repl-daemon-token-hint = 🔐 已设置 ANYCODE_DAEMON_TOKEN：POST /v1/tasks 需 Authorization: Bearer … 或 X-Anycode-Token
repl-daemon-stop-hint = 按 Ctrl+C 停止
repl-daemon-shutdown = 🛑 正在关闭…
repl-err-invalid-bind = 无效绑定地址 {$bind}: {$err}
repl-test-checking = 🔍 检查工具调用：{$tool}
repl-test-input =    输入：{$input}
repl-test-approved = ✅ 工具调用已批准
repl-test-denied = ❌ 工具调用已拒绝
repl-test-error = ❌ 错误：{$err}
repl-resume-not-found = 找不到该 id 的已保存会话（见 ~/.anycode/tui-sessions/）。
repl-session-list-title = 已保存会话（新→旧）：
repl-session-list-empty = （~/.anycode/tui-sessions/ 下暂无会话）
repl-session-list-err = 无法列出会话：
repl-session-applied = 已恢复会话 · id {$id}
repl-session-resolve-none = 当前目录下没有匹配的已保存会话（且无全局回退）。
repl-session-bad-uuid = 无效的会话 id（需要 UUID）。
repl-paste-clipboard-failed = 无法读取系统剪贴板（可试 Ctrl+Shift+V，或安装 pbpaste / wl-paste / xclip）。
repl-paste-need-line-edit = /paste 仅在带输入底栏的交互行式 REPL 中可用（非管道 stdio）。
